# Normalize line endings to LF on checkout for consistency across OS
* text=auto eol=lf

# Force LF for these file types explicitly
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.mjs   text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.woff  binary
*.woff2 binary
